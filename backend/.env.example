# ============================================================
# ProcureTask - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: Never commit your real .env file to source control.
# ============================================================

# Server port (default: 5000)
PORT=5000

# MongoDB connection string
# Local:  mongodb://localhost:27017/procuretrack
# Cloud:  mongodb+srv://<user>:<password>@cluster.mongodb.net/procuretrack
MONGO_URI=mongodb://localhost:27017/procuretrack

# JWT secret key — use any long random string in production
JWT_SECRET=your_jwt_secret_key_here
